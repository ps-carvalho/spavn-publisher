# Publisher CMS Environment Variables
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
PUBLISHER_SECRET=

# Optional: Override default SQLite database path
# DATABASE_URL=

# ─── WebAuthn/Passkey Settings ────────────────────────────────────────────────
# Configure the Relying Party (RP) for WebAuthn/passkey authentication.
# The RP ID must match the domain where the app is hosted.

# Human-readable name shown in passkey prompts
PUBLISHER_RP_NAME=Publisher CMS

# Relying Party ID — must match the domain (e.g., 'example.com')
# Use 'localhost' for development
PUBLISHER_RP_ID=localhost

# Full origin URL including protocol and port
# Must match the URL users access the app from
PUBLISHER_RP_ORIGIN=http://localhost:3000

# ─── TOTP Settings ────────────────────────────────────────────────────────────
# Configure the TOTP authenticator app integration.

# Issuer name shown in authenticator apps (e.g., Google Authenticator, Authy)
PUBLISHER_TOTP_ISSUER=Publisher CMS

# ─── Security Settings ────────────────────────────────────────────────────────
# Device tracking and new-device alert configuration.

# Send email notification when a new/untrusted device signs in
PUBLISHER_NOTIFY_NEW_DEVICES=true

# Maximum number of tracked devices per user (oldest are pruned)
PUBLISHER_MAX_DEVICES_PER_USER=10

# Enable device fingerprinting and tracking
PUBLISHER_DEVICE_TRACKING=true

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION SECURITY NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# IMPORTANT: In-Memory Stores (Rate Limiting & WebAuthn Challenges)
# ───────────────────────────────────────────────────────────────────────────────
# The default rate limiting and WebAuthn challenge stores use in-memory Maps.
# This is suitable for development and single-instance deployments.
#
# For PRODUCTION with multiple server instances or horizontal scaling:
# - Rate limiting: Replace with Redis to share state across instances
# - WebAuthn challenges: Replace with Redis to share state across instances
# - Session storage: Use Redis-backed sessions
#
# Without Redis in multi-instance deployments:
# - Rate limits can be bypassed (each instance has its own counter)
# - WebAuthn challenges may not be found (stored on different instance)
# - Users may experience intermittent failures during authentication
#
# Recommended Redis configuration:
#   REDIS_URL=redis://localhost:6379
#   REDIS_PASSWORD=your-redis-password (if using AUTH)
#
# Then configure the stores in server/utils/publisher/rateLimit.ts and
# server/utils/publisher/challengeStore.ts to use Redis instead of Maps.
#
# Alternative: Use sticky sessions (load balancer affinity) to route users
# to the same instance, though this is less robust than Redis.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Email Configuration ──────────────────────────────────────────────────────
# Email is required for passwordless (magic link) authentication.
# Choose a provider and configure it below, then uncomment the matching
# provider block in publisher.config.ts.

# Email provider to use. Options: smtp, sendgrid
# PUBLISHER_EMAIL_PROVIDER=smtp

# Default sender address (used by all providers)
# PUBLISHER_EMAIL_FROM=Publisher CMS <noreply@example.com>

# ─── SMTP Configuration ──────────────────────────────────────────────────────
# Works with any SMTP server: Gmail, Mailgun, Amazon SES, Postmark, etc.
# To enable: set PUBLISHER_EMAIL_PROVIDER=smtp and uncomment the smtp provider
# in publisher.config.ts

# SMTP server hostname (e.g., smtp.gmail.com, smtp.mailgun.org)
# SMTP_HOST=smtp.example.com

# SMTP server port (587 for TLS/STARTTLS, 465 for SSL)
# SMTP_PORT=587

# SMTP authentication credentials
# SMTP_USER=
# SMTP_PASS=

# ─── SendGrid Configuration ──────────────────────────────────────────────────
# Requires a SendGrid account (https://sendgrid.com)
# To enable: set PUBLISHER_EMAIL_PROVIDER=sendgrid and uncomment the sendgrid
# provider in publisher.config.ts

# SendGrid API key (create at Settings → API Keys, starts with 'SG.')
# SENDGRID_API_KEY=

# ─── Gmail SMTP Setup Guide ─────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Set the following variables:
#    SMTP_HOST=smtp.gmail.com
#    SMTP_PORT=587
#    SMTP_USER=your-email@gmail.com
#    SMTP_PASS=your-app-password
#    PUBLISHER_EMAIL_FROM=Your App <your-email@gmail.com>

# ─── Amazon SES SMTP Setup Guide ────────────────────────────────────────────
# 1. Verify your sender domain/email in SES console
# 2. Create SMTP credentials in SES → SMTP Settings
# 3. Set the following variables:
#    SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#    SMTP_PORT=587
#    SMTP_USER=your-ses-smtp-username
#    SMTP_PASS=your-ses-smtp-password
#    PUBLISHER_EMAIL_FROM=noreply@your-verified-domain.com

# ─── Storage Configuration ────────────────────────────────────────────────────
# The default storage provider. Options: local, r2, s3
# PUBLISHER_STORAGE_DEFAULT=local

# ─── Local Storage ────────────────────────────────────────────────────────────
# Directory where uploaded files are stored (relative to project root or absolute)
# Default: public/uploads
# PUBLISHER_UPLOAD_DIR=public/uploads

# URL path prefix for serving locally stored files
# Default: /uploads
# PUBLISHER_UPLOAD_URL=/uploads

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
# R2 is S3-compatible object storage with zero egress fees.
# To enable: set PUBLISHER_STORAGE_DEFAULT=r2 and uncomment the r2 provider
# in publisher.config.ts

# Cloudflare account ID (found in R2 dashboard → Overview)
# PUBLISHER_R2_ACCOUNT_ID=

# R2 bucket name
# PUBLISHER_R2_BUCKET=

# R2 API token credentials (create at Cloudflare dashboard → R2 → Manage R2 API Tokens)
# PUBLISHER_R2_ACCESS_KEY_ID=
# PUBLISHER_R2_SECRET_ACCESS_KEY=

# R2 region (default: auto)
# PUBLISHER_R2_REGION=auto

# Custom domain for public R2 URLs (optional)
# If set, files will be served from this domain instead of the R2 public URL
# Example: https://media.example.com
# PUBLISHER_R2_CUSTOM_DOMAIN=

# ─── S3-Compatible Storage ────────────────────────────────────────────────────
# Works with AWS S3, MinIO, DigitalOcean Spaces, Backblaze B2, etc.
# To enable: set PUBLISHER_STORAGE_DEFAULT=s3 and uncomment the s3 provider
# in publisher.config.ts

# S3 bucket name
# PUBLISHER_S3_BUCKET=

# AWS region (e.g., us-east-1, eu-west-1)
# PUBLISHER_S3_REGION=us-east-1

# AWS/S3 credentials
# PUBLISHER_S3_ACCESS_KEY_ID=
# PUBLISHER_S3_SECRET_ACCESS_KEY=

# Custom endpoint for S3-compatible services (optional)
# MinIO: http://localhost:9000
# DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# Backblaze B2: https://s3.us-west-004.backblazeb2.com
# PUBLISHER_S3_ENDPOINT=

# Custom domain for public S3 URLs (optional)
# PUBLISHER_S3_CUSTOM_DOMAIN=

# ─── AWS S3 IAM Permissions ──────────────────────────────────────────────────
# For production, create an IAM user with minimal permissions.
# Required permissions: s3:PutObject, s3:GetObject, s3:DeleteObject, s3:ListBucket
#
# Example IAM policy (attach to user or role):
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "s3:PutObject",
#         "s3:GetObject",
#         "s3:DeleteObject",
#         "s3:ListBucket"
#       ],
#       "Resource": [
#         "arn:aws:s3:::your-bucket-name",
#         "arn:aws:s3:::your-bucket-name/*"
#       ]
#     }
#   ]
# }
#
# SECURITY NOTES:
# - Never commit credentials to version control
# - Use environment variables or AWS Secrets Manager in production
# - Rotate access keys regularly
# - Enable bucket logging for audit trails
# - Consider using CloudFront for CDN with signed URLs for private content

# ─── MinIO Setup Guide ───────────────────────────────────────────────────────
# 1. Install MinIO: https://min.io/docs/minio/linux/operations/install-deploy-manage/deploy-minio-single-node-single-drive.html
# 2. Start MinIO server: minio server /data --console-address ":9001"
# 3. Access console at http://localhost:9001 (default: minioadmin/minioadmin)
# 4. Create a bucket for Publisher uploads
# 5. Create access keys in Identity → Service Accounts
# 6. Set the following variables:
#    PUBLISHER_S3_BUCKET=your-bucket-name
#    PUBLISHER_S3_REGION=us-east-1  # MinIO ignores this but SDK requires it
#    PUBLISHER_S3_ACCESS_KEY_ID=your-access-key
#    PUBLISHER_S3_SECRET_ACCESS_KEY=your-secret-key
#    PUBLISHER_S3_ENDPOINT=http://localhost:9000
#    # In publisher.config.ts, set forcePathStyle: true for MinIO

# ─── DigitalOcean Spaces Setup Guide ─────────────────────────────────────────
# 1. Create a Space in DigitalOcean control panel (https://cloud.digitalocean.com/spaces)
# 2. Generate Spaces access keys in API → Spaces/Keys
# 3. Set the following variables:
#    PUBLISHER_S3_BUCKET=your-space-name
#    PUBLISHER_S3_REGION=nyc3  # Your Space's region
#    PUBLISHER_S3_ACCESS_KEY_ID=your-spaces-key
#    PUBLISHER_S3_SECRET_ACCESS_KEY=your-spaces-secret
#    PUBLISHER_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
#    PUBLISHER_S3_CUSTOM_DOMAIN=https://cdn.yourdomain.com  # Optional CDN
#
# Note: DigitalOcean Spaces uses the region in the endpoint URL.
# Available regions: nyc3, sfo2, sfo3, ams3, sgp1, fra1, syd1
